// Cache buster: timestamp del archivo en disco. Cuando editamos un asset, su
// mtime cambia y el navegador descarga la versión nueva sin tener que
// invalidar manualmente.
$assetVer = function (string $path): string {
    $abs = dirname(__DIR__, 2) . '/../httpdocs' . $path;
    return is_file($abs) ? (string) filemtime($abs) : '0';
};
