<script>
// ─── Auto-slug ──────────────────────────────────────────
function slugify(s) {
  return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'')
    .replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');
}
const nameEl = document.getElementById('name');
const slugEl = document.getElementById('slug');
let slugTouched = <?= $isNew ? 'false' : 'true' ?>;
slugEl.addEventListener('input', () => { slugTouched = true; });
nameEl.addEventListener('input', () => {
  if (!slugTouched) slugEl.value = slugify(nameEl.value);
});

// ─── Image manager ──────────────────────────────────────
const cloudName    = <?= json_encode(Cloudinary::cloudName()) ?>;
const uploadPreset = <?= json_encode(Cloudinary::uploadPreset()) ?>;
const imagesInput  = document.getElementById('images-input');
const imageList    = document.getElementById('image-list');

function readImages() {
  const v = imagesInput.value.trim();
  return v ? v.split('\n').filter(Boolean) : [];
}
function writeImages(arr) {
  imagesInput.value = arr.join('\n');
  renderImages();
}
function renderImages() {
  const arr = readImages();
  imageList.innerHTML = '';
  if (arr.length === 0) {
    imageList.innerHTML = '<div class="col-span-full text-xs text-carbon-soft p-4 border border-dashed border-silver-200 rounded-lg text-center">Sin imágenes</div>';
    return;
  }
  arr.forEach((url, i) => {
    const card = document.createElement('div');
    card.className = 'relative group rounded-lg overflow-hidden border border-silver-200 aspect-square';
    card.innerHTML = `
      <img src="${url}" class="w-full h-full object-cover">
      ${i === 0 ? '<span class="absolute top-1 left-1 bg-brand-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded">Principal</span>' : ''}
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition flex items-center justify-center gap-1 opacity-0 group-hover:opacity-100">
        ${i > 0 ? `<button type="button" data-act="up" data-i="${i}" class="bg-white text-xs px-2 py-1 rounded">←</button>` : ''}
        ${i < arr.length-1 ? `<button type="button" data-act="down" data-i="${i}" class="bg-white text-xs px-2 py-1 rounded">→</button>` : ''}
        <button type="button" data-act="del" data-i="${i}" class="bg-red-600 text-white text-xs px-2 py-1 rounded">✕</button>
      </div>
    `;
    imageList.appendChild(card);
  });
}
imageList.addEventListener('click', (e) => {
  const btn = e.target.closest('button[data-act]');
  if (!btn) return;
  const i = parseInt(btn.dataset.i);
  const arr = readImages();
  if (btn.dataset.act === 'del') arr.splice(i, 1);
  if (btn.dataset.act === 'up' && i > 0) [arr[i-1], arr[i]] = [arr[i], arr[i-1]];
  if (btn.dataset.act === 'down' && i < arr.length-1) [arr[i], arr[i+1]] = [arr[i+1], arr[i]];
  writeImages(arr);
});

// Pegar URL
document.getElementById('btn-add-url').addEventListener('click', () => {
  const url = prompt('Pega la URL de la imagen:');
  if (!url) return;
  const arr = readImages();
  arr.push(url.trim());
  writeImages(arr);
});

// Upload Cloudinary (widget oficial)
const btnUpload = document.getElementById('btn-upload');
if (btnUpload) {
  btnUpload.addEventListener('click', () => {
    if (!window.cloudinary) {
      alert('El widget de Cloudinary aún no cargó. Espera un segundo y vuelve a intentar.');
      return;
    }
    const widget = window.cloudinary.createUploadWidget({
      cloudName, uploadPreset,
      sources: ['local','url','camera'],
      multiple: true,
      maxFiles: 6,
      cropping: false,
      language: 'es',
      text: { es: { menu: { files: 'Mis archivos', web: 'Pegar URL' } } },
    }, (err, result) => {
      if (err) { console.error(err); return; }
      if (result && result.event === 'success') {
        const arr = readImages();
        arr.push(result.info.secure_url);
        writeImages(arr);
      }
    });
    widget.open();
  });
}

renderImages();
</script>

