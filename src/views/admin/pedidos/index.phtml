    <!-- Paginación -->
    <?php if ($result['pages'] > 1):
      $current = (int)$result['page'];
      $total   = (int)$result['pages'];
      $pages = [];
      if ($total <= 7) {
        $pages = range(1, $total);
      } else {
        $pages[] = 1;
        if ($current - 1 > 2) $pages[] = '...';
        for ($i = max(2, $current-1); $i <= min($total-1, $current+1); $i++) $pages[] = $i;
        if ($current + 1 < $total - 1) $pages[] = '...';
        $pages[] = $total;
      }
    ?>
      <nav class="flex flex-wrap justify-center items-center gap-1.5 text-sm">
        <?php if ($current > 1): ?>
          <a href="?<?= qs_orders($opts, ['p' => $current - 1]) ?>" class="h-9 px-2.5 inline-flex items-center justify-center rounded-md border border-silver-200 hover:bg-silver">←</a>
        <?php endif; ?>
        <?php foreach ($pages as $p): ?>
          <?php if ($p === '...'): ?>
            <span class="h-9 px-1 inline-flex items-center text-carbon-soft">…</span>
          <?php else: ?>
            <a href="?<?= qs_orders($opts, ['p' => $p]) ?>"
               class="min-w-9 h-9 px-2.5 inline-flex items-center justify-center rounded-md border text-xs <?= $p === $current ? 'border-brand-500 bg-brand-500 text-white font-semibold' : 'border-silver-200 hover:bg-silver' ?>">
              <?= $p ?>
            </a>
          <?php endif; ?>
        <?php endforeach; ?>
        <?php if ($current < $total): ?>
          <a href="?<?= qs_orders($opts, ['p' => $current + 1]) ?>" class="h-9 px-2.5 inline-flex items-center justify-center rounded-md border border-silver-200 hover:bg-silver">→</a>
        <?php endif; ?>
