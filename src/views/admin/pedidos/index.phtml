<?php
/** @var array $orders  conteos por status */
/** @var array $result  {items, total, page, pages, perPage} */
/** @var array $opts    {status, q, page}                       */

$badgeClass = [
    'PENDING'   => 'bg-amber-100 text-amber-800',
    'PAID'      => 'bg-brand-100 text-brand-800',
    'FAILED'    => 'bg-red-100 text-red-800',
    'SHIPPED'   => 'bg-blue-100 text-blue-800',
    'DELIVERED' => 'bg-silver text-carbon',
    'CANCELLED' => 'bg-silver text-carbon-soft',
];

function qs_orders(array $current, array $override = []): string {
    $merged = array_merge($current, $override);
    $merged = array_filter($merged, fn($v) => $v !== null && $v !== '' && $v !== false);
    // remover keys que no interesan para la URL
    unset($merged['perPage']);
    return http_build_query($merged);
}
