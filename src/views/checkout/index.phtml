<script>
(function () {
  const METHODS = <?= json_encode($methods, JSON_UNESCAPED_UNICODE) ?>;

  const moneyAmount = (n) => '$' + Number(n).toLocaleString('es-CO').replace(/,/g, '.');

  const $items   = document.getElementById('summary-items');
  const $sub     = document.getElementById('summary-subtotal');
  const $ship    = document.getElementById('summary-shipping');
  const $methodLine = document.getElementById('summary-method');
  const $eta     = document.getElementById('summary-eta');
  const $total   = document.getElementById('summary-total');
  const $btn     = document.getElementById('submit-btn');
  const $itemsIn = document.getElementById('items-json');
  const $addrBlock     = document.getElementById('shipping-address-block');
  const $termBlock     = document.getElementById('shipping-terminal-block');
  const $stateField    = document.getElementById('state-field');
  const $stateFixed    = document.getElementById('state-fixed-note');
  const $stateInput    = document.querySelector('input[name="shipping_state"]');
  const $addressInput  = document.querySelector('input[name="shipping_address"]');
  const $cityInput     = document.querySelector('input[name="shipping_city"]');
  const $shipSame      = document.querySelector('[data-ship-same]');
  const $shipFields    = document.querySelector('[data-shipping-fields]');
  const $docType       = document.querySelector('[data-doc-type]');

  // ─── Toggle persona natural ↔ jurídica ─────────────────
  function syncCustomerType() {
    const t = document.querySelector('input[name="customer_type"]:checked')?.value || 'natural';
    // Labels
    document.querySelectorAll('[data-label-natural]').forEach(el => el.classList.toggle('hidden', t !== 'natural'));
    document.querySelectorAll('[data-label-juridica]').forEach(el => el.classList.toggle('hidden', t !== 'juridica'));
    document.querySelectorAll('[data-label-doc-natural]').forEach(el => el.classList.toggle('hidden', t !== 'natural'));
    document.querySelectorAll('[data-label-doc-juridica]').forEach(el => el.classList.toggle('hidden', t !== 'juridica'));

    // Filtrar opciones del select de tipo de documento
    if ($docType) {
      let firstValid = null;
      [...$docType.options].forEach(opt => {
        const matches = opt.dataset.for === t;
        opt.hidden = !matches;
        opt.disabled = !matches;
        if (matches && firstValid === null) firstValid = opt.value;
      });
      // Si la opción actual no es válida para este tipo, selecciona la primera válida
      if ($docType.selectedOptions[0]?.hidden && firstValid) {
        $docType.value = firstValid;
      }
    }
  }
  document.querySelectorAll('[data-customer-type]').forEach(r => r.addEventListener('change', syncCustomerType));

  // ─── Toggle dirección de envío = facturación ──────────
  function syncShipSame() {
    if (!$shipSame || !$shipFields) return;
    const same = $shipSame.checked;
    $shipFields.classList.toggle('hidden', same);
    // Si está marcado, los campos de envío no son required (los copia el server desde billing)
    [$addressInput, $cityInput, $stateInput].forEach(inp => {
      if (!inp) return;
      if (same) {
        inp.required = false;
      } else {
        // Volver a setear required según el método activo
        toggleAddressBlocks();
      }
    });
  }
  if ($shipSame) $shipSame.addEventListener('change', syncShipSame);

  function selectedMethod() {
    const r = document.querySelector('input[name="shipping_method"]:checked');
    if (!r) return null;
    return METHODS.find(m => m.id === r.value) || null;
  }

  function highlightSelectedCard() {
    document.querySelectorAll('.shipping-option').forEach(el => {
      const radio = el.querySelector('input[type=radio]');
      const sel = radio && radio.checked;
      el.classList.toggle('border-brand-500', sel);
      el.classList.toggle('bg-brand-50/40', sel);
      el.classList.toggle('border-silver-200', !sel);
    });
  }

  function toggleAddressBlocks() {
    const m = selectedMethod();
    if (!m) return;

    if (m.requires_terminal) {
      // Bus → mostrar terminal, ocultar dirección de envío
      $addrBlock.classList.add('hidden');
      $termBlock.classList.remove('hidden');
      if ($addressInput) $addressInput.required = false;
      if ($cityInput) $cityInput.required = false;
      if ($stateInput) $stateInput.required = false;
    } else {
      // PCE u Oriente → mostrar dirección de envío
      $addrBlock.classList.remove('hidden');
      $termBlock.classList.add('hidden');

      // Si marcó "mismo que facturación", los campos no son required
      const same = $shipSame && $shipSame.checked;
      if ($addressInput) $addressInput.required = !same;
      if ($cityInput) $cityInput.required = !same;

      if (m.id === 'oriente_cercano') {
        $stateInput.value = 'Antioquia';
        $stateInput.readOnly = true;
        $stateField.classList.add('hidden');
        $stateFixed.classList.remove('hidden');
        $stateInput.required = false;
      } else {
        $stateInput.readOnly = false;
        $stateField.classList.remove('hidden');
        $stateFixed.classList.add('hidden');
        $stateInput.required = !same;
      }
    }
  }

  function recalc() {
    const items = (window.Cart && Cart.items()) || [];
    if (!items.length) {
      $items.innerHTML = '<li class="text-carbon-soft text-center py-4">Carrito vacío. <a href="/productos" class="text-brand-600 hover:underline">Ir al catálogo</a></li>';
      $btn.disabled = true;
      return;
    }
    $btn.disabled = false;
    $itemsIn.value = JSON.stringify(items);

    $items.innerHTML = items.map(it => `
      <li class="flex justify-between gap-2">
        <span class="truncate">${escapeHtml(it.name)} <span class="text-carbon-soft">×${it.qty}</span></span>
        <span class="font-medium">${moneyAmount(it.price * it.qty)}</span>
      </li>
    `).join('');

    const subtotal = items.reduce((s, i) => s + i.price * i.qty, 0);
    const m = selectedMethod();

    $sub.textContent = moneyAmount(subtotal);

    if (!m) {
      $ship.textContent = '—';
      $methodLine.textContent = '';
      $eta.classList.add('hidden');
      $total.textContent = moneyAmount(subtotal);
      return;
    }

    $methodLine.textContent = m.name;
    $ship.textContent = m.cost === 0 ? 'Pago al recibir' : moneyAmount(m.cost);
    $total.textContent = moneyAmount(subtotal + m.cost);
    $eta.innerHTML = '<strong>Tiempo estimado:</strong> ' + m.eta_label;
    $eta.classList.remove('hidden');
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  document.querySelectorAll('input[name="shipping_method"]').forEach(r => {
    r.addEventListener('change', () => {
      highlightSelectedCard();
      toggleAddressBlocks();
      recalc();
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    syncCustomerType();
    syncShipSame();
    highlightSelectedCard();
    toggleAddressBlocks();
    recalc();
  });
  document.addEventListener('cart:updated', recalc);
})();
</script>
