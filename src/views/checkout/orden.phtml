<?php if ($status === 'PENDING'): ?>
<script>
  // El carrito ya se materializó como pedido; vacía el localStorage para
  // que el usuario no quede con productos duplicados si vuelve atrás.
  if (window.Cart) Cart.clear();

  // Auto-refresh cada 6 segundos para detectar cuando el webhook actualiza
  // la orden a PAID. Se detiene si el usuario navega o si la pestaña está
  // oculta para no consumir batería innecesariamente.
  (function () {
    let timer = null;
    function tick() {
      if (document.visibilityState === 'visible') {
        location.reload();
      } else {
        timer = setTimeout(tick, 6000);
      }
    }
    timer = setTimeout(tick, 6000);
    window.addEventListener('beforeunload', () => { if (timer) clearTimeout(timer); });
  })();
</script>
<?php endif; ?>
