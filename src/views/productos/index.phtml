/** @var array $result */
/** @var array $categories */
/** @var array $brands */
/** @var array $opts */
/** @var ?array $currentCat */

function build_qs(array $current, array $override = []): string {
    $merged = array_merge($current, $override);
    $merged = array_filter($merged, fn($v) => $v !== null && $v !== '');
    return http_build_query($merged);
}
