  <script>
    // Toggle del panel de filtros en móvil. En desktop el CSS lo fuerza a
    // mostrarse siempre (.filter-panel { display:block } en >=1024px).
    (function () {
      const btn   = document.querySelector('[data-filter-toggle]');
      const panel = document.querySelector('[data-filter-panel]');
      if (!btn || !panel) return;
      btn.addEventListener('click', function () {
        const open = panel.getAttribute('data-open') === 'true';
        panel.setAttribute('data-open', open ? 'false' : 'true');
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        const chev = btn.querySelector('[data-filter-chevron]');
        if (chev) chev.style.transform = open ? '' : 'rotate(180deg)';
      });
    })();
  </script>

