      <?php if ($result['pages'] > 1):
        // ─── Paginación "ventana" con elipsis ────────────────
        // En lugar de pintar TODAS las páginas (que en móvil con 19+ páginas se
        // sale del viewport), mostramos:
        //   - primera y última siempre
        //   - 1 página antes y 1 después de la actual
        //   - '...' donde hay saltos
        $current = (int)$result['page'];
        $total   = (int)$result['pages'];
        $delta   = 1;
        $pages = [];
        if ($total <= 7) {
            $pages = range(1, $total);
        } else {
            $pages[] = 1;
            if ($current - $delta > 2) $pages[] = '...';
            $start = max(2, $current - $delta);
            $end   = min($total - 1, $current + $delta);
            for ($i = $start; $i <= $end; $i++) $pages[] = $i;
            if ($current + $delta < $total - 1) $pages[] = '...';
            $pages[] = $total;
        }
      ?>
        <nav class="mt-10 sm:mt-12 flex flex-wrap justify-center items-center gap-1 sm:gap-1.5 text-sm">
          
          <?php if ($current > 1): ?>
            <a href="?<?= build_qs($qsBase, ['p' => $current - 1]) ?>"
               aria-label="Página anterior"
               class="h-9 sm:h-10 px-2.5 sm:px-3 inline-flex items-center justify-center rounded-md border border-silver-200 hover:bg-silver">
              ←
            </a>
          <?php endif; ?>

          <?php foreach ($pages as $p): ?>
            <?php if ($p === '...'): ?>
              <span class="h-9 sm:h-10 px-1 inline-flex items-center justify-center text-carbon-soft">…</span>
            <?php else: ?>
              <a href="?<?= build_qs($qsBase, ['p' => $p]) ?>"
                 aria-current="<?= $p === $current ? 'page' : 'false' ?>"
                 class="min-w-9 sm:min-w-10 h-9 sm:h-10 px-2.5 sm:px-3 inline-flex items-center justify-center rounded-md border text-xs sm:text-sm <?= $p === $current ? 'border-brand-500 bg-brand-500 text-white font-semibold' : 'border-silver-200 hover:bg-silver' ?>">
                <?= $p ?>
              </a>
            <?php endif; ?>
          <?php endforeach; ?>

          
          <?php if ($current < $total): ?>
            <a href="?<?= build_qs($qsBase, ['p' => $current + 1]) ?>"
               aria-label="Página siguiente"
               class="h-9 sm:h-10 px-2.5 sm:px-3 inline-flex items-center justify-center rounded-md border border-silver-200 hover:bg-silver">
              →
            </a>
          <?php endif; ?>
        </nav>

        
        <p class="mt-3 sm:hidden text-center text-xs text-carbon-soft">
          Página <strong class="text-carbon"><?= $current ?></strong> de <?= $total ?>
        </p>
